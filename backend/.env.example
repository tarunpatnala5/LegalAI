# Copy this file to `.env` for LOCAL development only.
# Never commit the real `.env` file (it's already in .gitignore).
#
# In production (Render), do NOT use a .env file at all — instead set
# these same variable names as Environment Variables in the Render
# dashboard for your backend service. That keeps secrets and the
# database connection out of git entirely.

# Leave unset (or comment out) to use local SQLite for development.
# In production, set this to your Postgres connection string, e.g.
# from Neon, Supabase, or Render Postgres:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=

SECRET_KEY=change-this-to-a-long-random-string

TOGETHER_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
GOOGLE_TRANSLATE_API_KEY=
HUGGINGFACE_API_KEY=
